{
  "manifest_version": 3,
  "name": "Browser Remote Control",
  "description": "Universal browser remote control — HTTP polling bridge for Chrome & Firefox",
  "version": "2.0",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "alarms",
    "storage",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
