{
  "manifest_version": 2,
  "name": "Browser Remote Control",
  "description": "Universal browser remote control — HTTP polling bridge for Chrome & Firefox",
  "version": "2.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "remote-control@hermes",
      "strict_min_version": "57.0"
    }
  },
  "permissions": [
    "activeTab",
    "tabs",
    "alarms",
    "storage",
    "debugger",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
